# Supabase — Dunamis Space
# Copie para .env e preencha. A connection string com a senha do Postgres NÃO entra aqui.
PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Cache (Redis/Upstash) — OPCIONAL. Sem estas vars o app funciona normal (sem cache).
# Crie um banco em https://console.upstash.com e cole as credenciais REST.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Fila de jobs em segundo plano
# Service role do Supabase (Project Settings → API). NUNCA expor no cliente.
SUPABASE_SERVICE_ROLE_KEY=
# Segredo do Vercel Cron (defina o mesmo valor no painel da Vercel). Protege /api/cron/*.
CRON_SECRET=
